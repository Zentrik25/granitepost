# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — copy from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL= http://localhost:3000/

# Anon key — safe for the browser. Copy from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — NEVER expose to the browser or commit to version control.
# Copy from Supabase dashboard → Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://zimbabwenewsonline.com
NEXT_PUBLIC_SITE_NAME=Zimbabwe News Online

# ── On-demand ISR revalidation ────────────────────────────────────────────────
# Must match the secret checked in /api/revalidate.
# Generate with: openssl rand -base64 32
REVALIDATION_SECRET=replace-with-a-strong-random-string
